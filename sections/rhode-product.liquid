{% assign product = all_products[section.settings.product] %}

<div class="product-container">
  {% if product != blank %}
    <section class="hero-section">
      <div class="carousel" id="product-carousel">
        <div class="carousel-inner">
          {% for image in product.images %}
          <div class="carousel-item {% if forloop.first %}active{% endif %}">
            <img src="{{ image | image_url: width: 800 }}" alt="{{ image.alt | escape }}" class="hero-image">
          </div>
          {% endfor %}
        </div>
        <div class="carousel-dots">
          {% for i in (1..product.images.size) %}
          <span class="dot {% if forloop.first %}active{% endif %}"></span>
          {% endfor %}
        </div>
      </div>
      <div class="pagination-indicator">1 / {{ product.images.size }}</div>
    </section>

    <section class="product-info">
      <div class="rating-stars">
        <span class="stars">★★★★★</span>
        <span class="rating-count">(6,927)</span>
      </div>
      <h2 class="product-title">{{ product.title | upcase }}</h2>
      <p class="product-subtitle">{{ product.description | strip_html | truncate: 100 }}</p>

      <div class="swatch-container">
        <img src="{{ 'swatch.png' | asset_url }}" alt="Blush swatch" class="swatch-image">
      </div>

      {% form 'product', product %}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        <div class="cta-container">
          <button type="submit" class="buy-button">
            BUY — {{ product.price | money }}
          </button>
        </div>
      {% endform %}
    </section>
  {% else %}
    <div style="padding: 100px; text-align: center;">
      <h2>Please select a product in the section settings.</h2>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Rhode Product",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Select Product"
    }
  ],
  "presets": [
    {
      "name": "Rhode Product"
    }
  ]
}
{% endschema %}
