<div class="product-container">
  <section class="hero-section">
    <div class="carousel" id="product-carousel">
      <div class="carousel-inner">
        {% for image in product.images %}
        <div class="carousel-item {% if forloop.first %}active{% endif %}">
          <img src="{{ image | image_url: width: 800 }}" alt="{{ image.alt | escape }}" class="hero-image">
        </div>
        {% else %}
        <div class="carousel-item active">
          <img src="{{ 'hero.png' | asset_url }}" alt="Pocket Blush Teacup" class="hero-image">
        </div>
        {% endfor %}
      </div>
      <div class="carousel-dots">
        {% assign image_count = product.images.size %}
        {% if image_count == 0 %}{% assign image_count = 1 %}{% endif %}
        {% for i in (1..image_count) %}
        <span class="dot {% if forloop.first %}active{% endif %}"></span>
        {% endfor %}
      </div>
    </div>
    <div class="pagination-indicator">1 / {{ image_count }}</div>
  </section>

  <section class="product-info">
    <div class="rating-stars">
      <span class="stars">★★★★★</span>
      <span class="rating-count">(6,927)</span>
    </div>
    <h2 class="product-title">{{ product.title | upcase }}</h2>
    <p class="product-subtitle">{{ product.description | strip_html | truncate: 60 }}</p>

    <div class="swatch-container">
      <img src="{{ 'swatch.png' | asset_url }}" alt="Blush swatch" class="swatch-image">
    </div>

    {% form 'product', product %}
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
      <div class="cta-container">
        <button type="submit" class="buy-button">
          BUY — {{ product.price | money }}
        </button>
      </div>
    {% endform %}
  </section>
</div>
